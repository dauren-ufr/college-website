rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    function isValidComment() {
      return request.resource.data.keys().hasAll(['name', 'text', 'likes'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.likes == 0;
    }

    // Site settings — public read, authenticated admin create/update
    match /settings/{docId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // News — public read, admin write
    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specializations — public read, admin write
    match /specializations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Applications — public create only, admin read/write/delete
    match /applications/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Comments — public read/create; public can increment likes; admin delete
    match /comments/{docId} {
      allow read: if true;
      allow create: if isValidComment();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        && request.resource.data.likes == (resource.data.keys().hasAny(['likes']) ? resource.data.likes : 0) + 1
      );
      allow delete: if isAdmin();
    }

    // Gallery — public read, admin write
    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
